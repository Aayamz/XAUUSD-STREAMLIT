# --- MT5 credentials (do NOT commit real values) -----------------------------
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# --- Mode --------------------------------------------------------------------
# "demo" uses the account above; "mock" never touches MT5 (uses simulated feed).
TRADING_MODE=demo

# --- Telegram alerts (optional) ----------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Security ----------------------------------------------------------------
# Used to encrypt MT5 credentials at rest in the local settings DB.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Dashboard ----------------------------------------------------------------
DASHBOARD_PORT=8501
DASHBOARD_HOST=localhost
